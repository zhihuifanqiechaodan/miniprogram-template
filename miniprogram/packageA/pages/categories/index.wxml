<!-- pages/categories/index.wxml -->
<view class="page-container">
  <custom-nav-bar
    showBack="{{true}}"
    title="分类管理"
    placeholder="{{true}}"
    custom-style="background-color: #ffffff;"
  />
  <view class="content-wrapper">
    <view class="tip-box">
      <text class="tip-text">💡 提示：可以添加、编辑、删除和排序分类。分类下有菜品时无法删除。</text>
    </view>
    <view class="stats-row">
      <text class="stats-title">分类统计</text>
      <view class="stats-categories">
        <text class="stats-count">{{totalCategories}}</text>
        <text>个分类</text>
      </view>
      <view class="stats-products">共 {{totalProducts}} 个菜品</view>
    </view>
    <view class="category-list">
      <view class="category-item" wx:for="{{categories}}" wx:key="id">
        <view class="left-section">
          <view class="sort-buttons">
            <view class="sort-btn up" catchtap="onSortUp" data-index="{{index}}" wx:if="{{index > 0}}">▲</view>
            <view
              class="sort-btn down"
              catchtap="onSortDown"
              data-index="{{index}}"
              wx:if="{{index < categories.length - 1}}"
              >▼</view
            >
          </view>
          <view class="category-icon-wrapper"> {{item.icon}} </view>
          <view class="category-info">
            <text class="category-name">{{item.name}}</text>
            <text class="category-meta" wx:if="{{item.count}}">{{item.count}} 个菜品</text>
            <text class="category-meta" wx:else>暂无菜品</text>
          </view>
        </view>
        <view class="right-section">
          <view class="action-btn" catchtap="onEditCategory" data-id="{{item.id}}"> 编辑 </view>
          <view class="action-btn" catchtap="onDeleteCategory" data-id="{{item.id}}"> 删除 </view>
        </view>
      </view>
    </view>
    <view class="fixed-bottom-wrapper">
      <view class="add-btn" bindtap="onAddCategory">
        <text class="plus-icon">+</text>
        <text>添加新分类</text>
      </view>
    </view>
  </view>
</view>
