<!-- pages/course-detail/index.wxml -->
<view class="page-container">
  <com-nav-bar
    placeholder="{{true}}"
    showBack="{{true}}"
    title="{{course ? course.name : '课程详情'}}"
    custom-style="background: rgba(255, 255, 255, 1);"
    bind:onBack="handleNavigateBack"
  />
  <view class="content-wrapper">
    <view class="course-info-section" wx:if="{{course}}">
      <text class="course-code">{{course.code}}</text>
      <text class="course-name">{{course.name}}</text>
      <view class="tag-list">
        <block wx:for="{{displayTagList}}" wx:key="text">
          <text class="tag-item tag-item-{{item.tone}}">{{item.text}}</text>
        </block>
      </view>
      <view class="description-card">
        <text class="description-text">{{course.description || '暂无课程介绍'}}</text>
      </view>
    </view>

    <view class="rating-card" wx:if="{{course}}">
      <view class="rating-header">
        <text class="rating-title">综合评分</text>
        <view class="rating-value-wrap">
          <text class="rating-value">{{course.rating !== null ? course.rating.toFixed(1) : '--'}}</text>
          <text class="star-icon">★</text>
        </view>
      </view>
      <view class="rating-metric-list">
        <block wx:for="{{ratingDisplayList}}" wx:key="key">
          <view class="rating-metric-item">
            <text class="metric-label">{{item.label}}</text>
            <view class="metric-bar">
              <view class="metric-bar-fill metric-bar-fill-{{item.tone}}" style="width: {{item.percent + '%'}}"></view>
            </view>
            <text class="metric-value">{{item.displayValue}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="reviews-section" wx:if="{{hotReviewList.length}}">
      <text class="reviews-title">精选评价</text>
      <view class="review-list">
        <block wx:for="{{hotReviewList}}" wx:key="id">
          <view class="review-item">
            <view class="review-header">
              <view class="review-user">
                <view class="avatar-wrap">{{item.userInitial}}</view>
                <text class="review-author">{{item.userNickname}}</text>
              </view>
              <text class="review-date">{{item.createdAtText}}</text>
            </view>
            <text class="review-content">{{item.content}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="fab-button" catch:tap="handleWriteReview">
    <text class="fab-icon">✎</text>
  </view>
</view>

<van-toast id="van-toast" />
