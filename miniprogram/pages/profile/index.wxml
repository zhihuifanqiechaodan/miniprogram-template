<!-- pages/profile/index.wxml -->
<wxs src="/utils/wxs.wxs" module="commModule" />
<view class="tabbar-page-container profile-page">
  <com-nav-bar placeholder="{{true}}" custom-style="background: transparent;" />
  <scroll-view class="content-scroll" scroll-y enable-flex show-scrollbar="{{false}}">
    <view class="content-wrapper">
      <view class="profile-card">
        <view class="profile-card-decor"></view>

        <view class="profile-main">
          <view class="profile-avatar-wrap">
            <com-image
              wx:if="{{userInfo && userInfo.avatarUrl}}"
              src="{{userInfo.avatarUrl}}"
              class="profile-avatar"
              radius="50%"
            />
            <view wx:else class="profile-avatar">
              <text>{{userInfo && userInfo.nickname ? commModule.slice(userInfo.nickname, 1) : ''}}</text>
            </view>
            <view class="profile-vip-icon">
              <van-icon name="vip-card" class="profile-vip-mark" />
            </view>
          </view>

          <view class="profile-info">
            <view class="name-row">
              <text class="profile-name">{{userInfo && userInfo.nickname ? userInfo.nickname : ''}}</text>
              <view wx:if="{{userInfo && userInfo.isSchoolVerified}}" class="verified-tag">
                <van-icon name="passed" class="verified-icon" />
                <text>已认证</text>
              </view>
              <view wx:if="{{userInfo && userInfo.status === 'normal'}}" class="member-tag">
                <text class="member-text">VIP</text>
                <van-icon name="arrow" class="member-arrow" />
              </view>
            </view>

            <view class="meta-column">
              <view class="meta-row">
                <van-icon name="wap-home-o" class="meta-icon" />
                <text>{{userInfo && userInfo.schoolId ? userInfo.schoolId : ''}}</text>
              </view>
              <view class="meta-row secondary">
                <van-icon name="notes-o" class="meta-icon" />
                <text>{{userInfo && userInfo.bio ? userInfo.bio : ''}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="stats-row">
          <block wx:for="{{statsList}}" wx:key="label" wx:for-item="stat">
            <view class="stats-item">
              <text class="stats-value">{{stat.value}}</text>
              <text class="stats-label">{{stat.label}}</text>
            </view>
            <view wx:if="{{stat.showDivider}}" class="stats-divider"></view>
          </block>
        </view>
      </view>

      <block wx:for="{{menuSections}}" wx:key="key" wx:for-item="section">
        <view class="menu-card">
          <block wx:for="{{section.items}}" wx:key="type" wx:for-item="menu">
            <view
              class="menu-item"
              hover-class="menu-item-hover"
              hover-stay-time="80"
              data-type="{{menu.type}}"
              catch:tap="handleNavigate"
            >
              <view class="menu-left">
                <view class="menu-icon-wrap {{menu.tone}}">
                  <van-icon name="{{menu.icon}}" class="menu-icon" />
                </view>
                <text class="menu-label">{{menu.label}}</text>
              </view>
              <van-icon name="arrow" class="menu-arrow" />
            </view>
          </block>
        </view>
      </block>
    </view>
  </scroll-view>
</view>

<van-toast id="van-toast" />
