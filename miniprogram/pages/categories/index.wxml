<!-- pages/categories/index.wxml -->
<view class="app-container">
  <custom-nav-bar placeholder="{{true}}" title="商品分类" />
  <custom-broken-network wx:if="{{brokenNetwork}}" />
  <view class="categories-wrapper">
    <scroll-view
      scroll-y="true"
      style="width: 160rpx; height: calc(100vh - {{systemInfo.menuButton.bottom}}px - var(--tabbar-height) - env(safe-area-inset-bottom));"
    >
      <view class="categories-wrapper">
        <view class="categories-item" wx:for="{{categories}}" wx:key="{{item.id}}">
          <view class="categories-item-name">{{item.name}}</view>
        </view>
      </view>
    </scroll-view>
    <view class="tabs-wrapper">
      <van-tabs active="{{ currentTab }}" bind:change="onChange">
        <van-tab wx:for="{{categories}}" wx:key="_id" title="{{item.name}}">
          <scroll-view
            scroll-y
            style="height: calc(100vh - {{systemInfo.menuButton.bottom}}px - var(--tabbar-height) - env(safe-area-inset-bottom))"
          >
            <block wx:for="{{item.data}}" wx:for-item="dataItem" wx:for-index="index" wx:key="index">
              <view wx:for="{{dataItem}}" wx:key="_id" class="goods-item">
                <custom-goods dataInfo="{{item}}" width="100%" height="320rpx" />
              </view>
            </block>
          </scroll-view>
        </van-tab>
      </van-tabs>
    </view>
  </view>
</view>
