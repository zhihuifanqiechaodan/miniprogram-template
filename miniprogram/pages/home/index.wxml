<!-- pages/home/index.wxml -->
<view class="tabbar-page-container home-page">
  <com-nav-bar placeholder="{{true}}" custom-style="background: transparent;" />

  <view class="content">
    <view class="hero">
      <view class="orb primary"></view>
      <view class="orb accent"></view>

      <view class="heading">
        <text class="title">拒绝挂科</text>
        <text class="title accent">选课不踩雷</text>
      </view>
      <text class="subtitle">澳洲留学生专属课程评价平台</text>

      <view class="search-panel">
        <view class="search-icon-wrap">
          <van-icon name="search" class="search-icon" />
        </view>
        <input
          class="search-input"
          value="{{keyword}}"
          placeholder="搜索课程代码 (e.g. COMP9021)..."
          placeholder-class="search-placeholder"
          confirm-type="search"
          cursor-spacing="32"
          bindinput="handleKeywordInput"
          bindconfirm="handleSearch"
        />
        <view class="search-button" catch:tap="handleSearch">搜索</view>
      </view>

      <view class="stats">
        <view class="stats-item">
          <text class="stats-label">已收录</text>
          <text class="stats-value">{{statsModule.formatCount(statsOverview.courseCount)}}</text>
        </view>
        <view class="stats-item highlight">
          <text class="stats-label">真实评价</text>
          <text class="stats-value">{{statsModule.formatCount(statsOverview.reviewCount)}}</text>
        </view>
        <view class="stats-item">
          <text class="stats-label">用户</text>
          <text class="stats-value">{{statsModule.formatCount(statsOverview.registeredUserCount)}}</text>
        </view>
      </view>
    </view>
    <view class="section-bar">
      <view class="section-title">
        <van-icon name="fire" class="section-icon" />
        <text class="section-text">热门推荐</text>
      </view>
      <view class="section-action" catch:tap="handleResetFilter">
        <text class="section-action-text">全部</text>
        <van-icon name="arrow" class="section-action-icon" />
      </view>
    </view>

    <scroll-view class="scroll" scroll-y show-scrollbar="{{false}}">
      <view class="list">
        <block wx:for="{{displayCourseList}}" wx:key="id">
          <view class="course-item">
            <com-course-card course="{{item}}" bind:cardtap="handleCourseTap" />
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>

<van-toast id="van-toast" />

<!-- prettier-ignore -->
<wxs module="statsModule">
  function formatCount(value) {
    if (value === undefined || value === null || value === '') {
      return '--';
    }

    var numberValue = +value;
    if (numberValue !== numberValue) {
      return '--';
    }

    if (numberValue >= 1000) {
      var kValue = numberValue / 1000;
      var fixed = kValue >= 10 ? kValue.toFixed(0) : kValue.toFixed(1);
      if (fixed.indexOf('.0') === fixed.length - 2) {
        fixed = fixed.slice(0, fixed.length - 2);
      }
      return fixed + 'k';
    }

    return '' + numberValue;
  }

  module.exports = {
    formatCount: formatCount,
  };
</wxs>
