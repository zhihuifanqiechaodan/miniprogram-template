<!-- pages/login/index.wxml -->
<view class="page-container login-page">
  <view class="content">
    <view class="logo-wrap">
      <view class="logo-box">
        <com-image
          width="160rpx"
          height="160rpx"
          src="/assets/images/forum.svg"
          mode="aspectFit"
          show-loading="{{false}}"
          show-error="{{false}}"
          placeholder="{{false}}"
        />
      </view>
    </view>

    <text class="title">欢迎回来</text>
    <text class="subtitle">登录 IRBTree 小程序</text>

    <view class="form">
      <view class="field-card">
        <van-field
          custom-class="field-control"
          input-class="field-input"
          center="{{true}}"
          border="{{false}}"
          clearable="{{true}}"
          value="{{email}}"
          maxlength="30"
          placeholder="邮箱"
          bind:input="handleEmailInput"
        />
      </view>

      <view class="field-card">
        <van-field
          custom-class="field-control"
          input-class="field-input"
          center="{{true}}"
          border="{{false}}"
          clearable="{{true}}"
          type="password"
          value="{{password}}"
          maxlength="30"
          placeholder="密码"
          bind:input="handlePasswordInput"
        />
      </view>

      <van-button block color="#4f46e5" custom-class="submit-button" catch:click="handleLogin"> 登录 </van-button>
    </view>
  </view>
</view>

<van-toast id="van-toast" />
