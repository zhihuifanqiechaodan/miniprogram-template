{
  "tabBar": {
    "custom": true,
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/categories/index",
        "text": "分类"
      },
      {
        "pagePath": "pages/device/index",
        "text": "设备"
      },
      {
        "pagePath": "pages/carts/index",
        "text": "购物车"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的"
      }
    ]
  },
  "pages": [
    "pages/home/index",
    "pages/guide/index",
    "pages/categories/index",
    "pages/device/index",
    "pages/carts/index",
    "pages/profile/index"
  ],
  "subPackages": [
    {
      "root": "packageA",
      "name": "packageA",
      "pages": [
        "pages/goods-detail/index",
        "pages/address/index",
        "pages/address-edit/index",
        "pages/order-confirm/index",
        "pages/order-list/index",
        "pages/order-detail/index",
        "pages/search/index",
        "pages/sign-in/index",
        "pages/web-view/index"
      ]
    },
    {
      "root": "packageB",
      "name": "packageB",
      "pages": [
        "pages/admin-backend/index",
        "pages/admin-banner/index",
        "pages/admin-category/index",
        "pages/admin-product/index"
      ]
    }
  ],
  "window": {
    "navigationBarTitleText": "视力优",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTextStyle": "black",
    "navigationStyle": "custom",
    "backgroundTextStyle": "light"
  },
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "defaultContentBox": true,
      "tagNameStyleIsolation": "legacy",
      "disableABTest": true,
      "sdkVersionBegin": "3.0.0",
      "sdkVersionEnd": "15.255.255"
    }
  },
  "componentFramework": "glass-easel",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "resolveAlias": {
    "@miniprogram/*": "/*",
    "@vant/*": "/miniprogram_npm/@vant/*",
    "@/*": "../*"
  },
  "requiredPrivateInfos": ["chooseAddress"]
}
