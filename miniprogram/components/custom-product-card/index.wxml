<!-- components/custom-product-card/index.wxml -->
<view
  wx:if="{{dataInfo}}"
  catch:tap="handleGoodsClick"
  style="width: {{width}};"
  style="width: {{layout === 'vertical' ? width : '100%'}};"
  class="custom-product-card {{ wxsModule.computedLayout(layout) }}"
>
  <view class="product-image-wrapper">
    <custom-image width="{{width}}" height="{{height}}" src="{{dataInfo.images[0]}}" />
    <view wx:if="{{discount > 0}}" class="promo-badge">
      <text class="promo-text">限时特惠</text>
      <text class="promo-discount">-{{discount}}%</text>
    </view>
    <view class="rating-badge">
      <text class="star-icon">★</text>
      <text class="rating-text">4.8</text>
    </view>
  </view>
  <view class="product-info">
    <view wx:if="{{dataInfo.category_name}}" class="product-meta">
      <view class="category-tag">{{dataInfo.category_name}}</view>
      <text class="sales-text">已售1200+</text>
    </view>
    <view wx:else class="product-meta-simple">
      <text class="sales-text">已售1200+</text>
    </view>
    <view class="product-name">{{dataInfo.name}}</view>
    <view class="product-desc">{{dataInfo.description}}</view>
    <view wx:if="{{dataInfo.skus.length === 1}}" class="single-spec">
      <text class="spec-label">规格：{{dataInfo.skus[0].name}}</text>
    </view>
    <view class="price-box">
      <view class="price-row">
        <view class="sale-price">
          <text class="price-symbol">¥</text>
          <text class="price-value"> {{dataInfo.skus[wxsModule.minSkuIndex(dataInfo)].sell_price}} </text>
        </view>
        <text class="original-price"> ¥{{dataInfo.skus[wxsModule.minSkuIndex(dataInfo)].original_price}} </text>
      </view>
      <text class="saved-amount">已省 ¥{{savedAmount}}</text>
    </view>
    <view class="add-cart-btn" bindtap="onAddToCart">
      <text class="cart-icon">🛒</text>
      <text class="cart-text">加入购物车</text>
    </view>
  </view>
  <!-- 规格选择弹窗 -->
  <view wx:if="{{showSpecModal}}" class="spec-modal">
    <!-- 遮罩层 -->
    <view class="modal-mask" bindtap="closeSpecModal" />
    <!-- 弹窗内容 -->
    <view class="modal-content" animation="{{modalAnimation}}">
      <!-- 商品信息 -->
      <view class="modal-header">
        <image class="modal-product-image" src="{{dataInfo.image}}" mode="aspectFill" />
        <view class="modal-product-info">
          <view class="modal-price">
            <text class="modal-price-symbol">¥</text>
            <text class="modal-price-value">{{selectedSpec.salePrice}}</text>
            <text class="modal-original-price">¥{{selectedSpec.originalPrice}}</text>
          </view>
          <text class="modal-product-name">{{dataInfo.name}}</text>
        </view>
        <view class="modal-close" bindtap="closeSpecModal">✕</view>
      </view>
      <!-- 规格选择 -->
      <view class="modal-body">
        <text class="spec-title">选择规格</text>
        <view class="spec-list">
          <view
            wx:for="{{dataInfo.specs}}"
            wx:key="id"
            class="spec-item {{selectedSpec.id === item.id ? 'spec-item-active' : ''}}"
            bindtap="onSelectSpec"
            data-spec="{{item}}"
          >
            {{item.name}}
          </view>
        </view>
      </view>
      <!-- 确认按钮 -->
      <view class="modal-footer">
        <view class="confirm-btn" bindtap="onConfirmSpec">
          <text class="confirm-icon">🛒</text>
          <text class="confirm-text">确认加入购物车</text>
        </view>
      </view>
    </view>
  </view>
</view>
<!-- prettier-ignore -->
<wxs module="wxsModule">
	module.exports = {
		minSkuIndex: function (data) {
			var minSkuIndex = 0
			for (var i = 0; i < data.skus.length; i++) {
				if (data.skus[i].sell_price < data.skus[minSkuIndex].sell_price) {
					minSkuIndex = i
				}
			}
			return minSkuIndex
		},
		computedLayout: function (layout) {
			var layoutClass = ''
			if (layout === 'horizontal') {
				layoutClass = 'custom-product-card-v2--horizontal'
			} else if (layout === 'vertical') {
				layoutClass = 'custom-product-card-v2--vertical'
			}
			return layoutClass
		}
	};
</wxs>
