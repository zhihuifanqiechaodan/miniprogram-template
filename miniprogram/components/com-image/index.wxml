<!--components/com-image/index.wxml-->
<view
  style="width: {{width}}; height: {{height}}; border-radius: {{radius ? radius : 0}}; {{customStyle}}"
  class="image-wrapper {{round ? 'image-round' : ''}} {{flex ? 'flex' : ''}}"
>
  <image
    src="{{wxsModule.processSrc({src, version})}}"
    mode="{{mode}}"
    webp="{{webp}}"
    lazy-load="{{lazyLoad}}"
    show-menu-by-longpress="{{showMenuByLongpress}}"
    binderror="error"
    bindload="load"
    class="image-img"
  />
  <slot />
  <view
    wx:if="{{ loading && showLoading }}"
    style="background-color: {{loadingBackground}};"
    class="image-loading {{round ? 'image-round' : ''}}"
  >
    <view wx:if="{{placeholder}}" class="image-skeleton">
      <view class="image-skeleton-shimmer"></view>
      <view class="image-skeleton-block image-skeleton-thumb"></view>
      <view class="image-skeleton-block image-skeleton-line image-skeleton-line-short"></view>
      <view class="image-skeleton-block image-skeleton-line"></view>
    </view>
  </view>
  <view wx:if="{{ error && showError }}" class="image-error {{round ? 'image-round' : ''}}">
    <view class="image-skeleton">
      <view class="image-skeleton-shimmer"></view>
      <view class="image-skeleton-block image-skeleton-thumb"></view>
      <view class="image-skeleton-block image-skeleton-line image-skeleton-line-short"></view>
      <view class="image-skeleton-block image-skeleton-line"></view>
    </view>
  </view>
</view>

<!-- prettier-ignore -->
<wxs module="wxsModule">
  var REGEXP = getRegExp('^-?\d+(\.\d+)?$');
  module.exports = {
    processSrc: function (data) {
      var src = data.src
      var version = data.version
      if (src.indexOf('://tmp/') > -1 || src.indexOf('wxfile://') > -1) {
        return src;
      }
      if (src.indexOf('://') > -1) {
        var hasParam = src.indexOf('?') > -1;
        src += hasParam ? '&_t=' + version : '?_t=' + version;
        if (src.indexOf('http://') === 0) {
          return src.replace('http://', 'https://');
        }
        return src;
      }
      return src;
    }
  }
</wxs>
