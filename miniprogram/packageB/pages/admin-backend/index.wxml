<!-- packageB/pages/admin-backend/index.wxml -->
<view class="app-container">
  <custom-nav-bar showBack="{{true}}" title="后台管理" placeholder="{{true}}" />
  <custom-broken-network wx:if="{{brokenNetwork}}" />
  <view class="admin-list">
    <view
      class="admin-item"
      wx:for="{{adminList}}"
      wx:key="{{item.name}}"
      bindtap="navigateToAdmin"
      data-path="{{item.path}}"
    >
      <view style="background-color: {{wxsModule.computedRandomColor()}}" class="admin-item-icon">{{item.icon}}</view>
      <view class="admin-item-info">
        <view class="admin-item-text">{{item.name}}</view>
        <view class="admin-item-count">共{{item.count}}条数据</view>
      </view>
      <view class="admin-item-arrow">></view>
    </view>
  </view>
</view>

<!-- prettier-ignore -->
<wxs module="wxsModule">
	module.exports = {
		computedRandomColor: function () {
			// 生成单个通道值（230-255）：对应EFF6FF的浅度区间，数值越高颜色越浅
			function getChannel() {
				// 25 = 255 - 230，区间越小颜色越接近EFF6FF的浅度
				return Math.floor(Math.random() * 25) + 230;
			}

			// ES5 手动补零（替代padStart）
			function padTwo(str) {
				return str.length === 1 ? '0' + str : str;
			}

			var r = padTwo(getChannel().toString(16));
			var g = padTwo(getChannel().toString(16));
			var b = padTwo(getChannel().toString(16));

			return '#' + r + g + b;
		},
	};
</wxs>
