page {
  /* Color Palette */
  --black: #000;
  --white: #fff;
  --gray-1: #f7f8fa;
  --gray-2: #f2f3f5;
  --gray-3: #ebedf0;
  --gray-4: #dcdee0;
  --gray-5: #c8c9cc;
  --gray-6: #969799;
  --gray-7: #646566;
  --gray-8: #323233;
  --red: #ee0a24;
  --blue: #1989fa;
  --orange: #ff976a;
  --orange-dark: #ed6a0c;
  --orange-light: #fffbe8;
  --green: #4f46e5;

  /* Gradient Colors */
  --gradient-red: linear-gradient(to right, #ff6034, #ee0a24);
  --gradient-orange: linear-gradient(to right, #ffd01e, #ff8917);

  /* Component Colors */
  --text-color: var(--gray-8);
  --active-color: var(--gray-2);
  --active-opacity: 0.7;
  --disabled-opacity: 0.5;
  --background-color: var(--gray-1);
  --background-color-light: #fafafa;
  --text-link-color: #576b95;

  /* Padding */
  --padding-base: 8rpx;
  --padding-xs: calc(var(--padding-base) * 2);
  --padding-sm: calc(var(--padding-base) * 3);
  --padding-md: calc(var(--padding-base) * 4);
  --padding-lg: calc(var(--padding-base) * 6);
  --padding-xl: calc(var(--padding-base) * 8);

  /* Font */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-weight-bold: 500;
  --line-height-xs: 28rpx;
  --line-height-sm: 36rpx;
  --line-height-md: 40rpx;
  --line-height-lg: 44rpx;
  --base-font-family:
    -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui',
    'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  --price-integer-font-family: Avenir-Heavy, PingFang SC, Helvetica Neue, Arial, sans-serif;

  /* Animation */
  --animation-duration-base: 0.3s;
  --animation-duration-fast: 0.2s;

  /* Border */
  --border-color: var(--gray-3);
  --border-width-base: 2rpx;
  --border-radius-sm: 4rpx;
  --border-radius-md: 8rpx;
  --border-radius-lg: 16rpx;
  --border-radius-max: 1998rpx;

  /* ActionSheet */
  --action-sheet-max-height: 90%;
  --action-sheet-header-height: 96rpx;
  --action-sheet-header-font-size: var(--font-size-lg);
  --action-sheet-description-color: var(--gray-6);
  --action-sheet-description-font-size: var(--font-size-md);
  --action-sheet-description-line-height: 40rpx;
  --action-sheet-item-background: var(--white);
  --action-sheet-item-font-size: var(--font-size-lg);
  --action-sheet-item-line-height: 44rpx;
  --action-sheet-item-text-color: var(--text-color);
  --action-sheet-item-disabled-text-color: var(--gray-5);
  --action-sheet-subname-color: var(--gray-6);
  --action-sheet-subname-font-size: var(--font-size-sm);
  --action-sheet-subname-line-height: 40rpx;
  --action-sheet-close-icon-size: 44rpx;
  --action-sheet-close-icon-color: var(--gray-5);
  --action-sheet-close-icon-padding: 0 var(--padding-md);
  --action-sheet-cancel-text-color: var(--gray-7);
  --action-sheet-cancel-padding-top: var(--padding-xs);
  --action-sheet-cancel-padding-color: var(--background-color);

  /* Button */
  --button-mini-height: 44rpx;
  --button-mini-min-width: 100rpx;
  --button-mini-font-size: var(--font-size-xs);
  --button-small-height: 60rpx;
  --button-small-font-size: var(--font-size-sm);
  --button-small-min-width: 120rpx;
  --button-normal-font-size: var(--font-size-md);
  --button-large-height: 100rpx;
  --button-default-color: var(--text-color);
  --button-default-height: 88rpx;
  --button-default-font-size: var(--font-size-lg);
  --button-default-background-color: var(--white);
  --button-default-border-color: var(--border-color);
  --button-primary-color: var(--white);
  --button-primary-background-color: var(--green);
  --button-primary-border-color: var(--green);
  --button-info-color: var(--white);
  --button-info-background-color: var(--blue);
  --button-info-border-color: var(--blue);
  --button-danger-color: var(--white);
  --button-danger-background-color: var(--red);
  --button-danger-border-color: var(--red);
  --button-warning-color: var(--white);
  --button-warning-background-color: var(--orange);
  --button-warning-border-color: var(--orange);
  --button-line-height: 40rpx;
  --button-border-width: 2rpx;
  --button-border-radius: var(--border-radius-sm);
  --button-round-border-radius: var(--border-radius-max);
  --button-plain-background-color: var(--white);
  --button-disabled-opacity: var(--disabled-opacity);

  /* Calendar */
  --calendar-height: 100%;
  --calendar-background-color: var(--white);
  --calendar-popup-height: 90%;
  --calendar-header-box-shadow: 0 4rpx 20rpx rgba(125, 126, 128, 0.16);
  --calendar-header-title-height: 88rpx;
  --calendar-header-title-font-size: var(--font-size-lg);
  --calendar-header-subtitle-font-size: var(--font-size-md);
  --calendar-weekdays-height: 60rpx;
  --calendar-weekdays-font-size: var(--font-size-sm);
  --calendar-month-title-font-size: var(--font-size-md);
  --calendar-month-mark-color: rgba(242, 243, 245, 0.8);
  --calendar-month-mark-font-size: 320rpx;
  --calendar-day-height: 128rpx;
  --calendar-day-font-size: var(--font-size-lg);
  --calendar-range-edge-color: var(--white);
  --calendar-range-edge-background-color: var(--red);
  --calendar-range-middle-color: var(--red);
  --calendar-range-middle-background-opacity: 0.1;
  --calendar-selected-day-size: 108rpx;
  --calendar-selected-day-color: var(--white);
  --calendar-info-font-size: var(--font-size-xs);
  --calendar-info-line-height: 28rpx;
  --calendar-selected-day-background-color: var(--red);
  --calendar-day-disabled-color: var(--gray-5);
  --calendar-confirm-button-height: 72rpx;
  --calendar-confirm-button-margin: 14rpx 0;
  --calendar-confirm-button-line-height: 68rpx;

  /* Card */
  --card-padding: var(--padding-xs) var(--padding-md);
  --card-font-size: var(--font-size-sm);
  --card-text-color: var(--text-color);
  --card-background-color: var(--background-color-light);
  --card-thumb-size: 176rpx;
  --card-title-line-height: 32rpx;
  --card-desc-color: var(--gray-7);
  --card-desc-line-height: 40rpx;
  --card-price-color: var(--red);
  --card-origin-price-color: var(--gray-7);
  --card-origin-price-font-size: var(--font-size-xs);
  --card-price-font-size: var(--font-size-sm);
  --card-price-integer-font-size: var(--font-size-lg);
  --card-price-font-family: var(--price-integer-font-family);

  /* Cell */
  --cell-font-size: var(--font-size-md);
  --cell-line-height: 48rpx;
  --cell-vertical-padding: 20rpx;
  --cell-horizontal-padding: var(--padding-md);
  --cell-text-color: var(--text-color);
  --cell-background-color: var(--white);
  --cell-border-color: var(--border-color);
  --cell-active-color: var(--active-color);
  --cell-required-color: var(--red);
  --cell-label-color: var(--gray-6);
  --cell-label-font-size: var(--font-size-sm);
  --cell-label-line-height: 36rpx;
  --cell-label-margin-top: 6rpx;
  --cell-value-color: var(--gray-6);
  --cell-icon-size: 32rpx;
  --cell-right-icon-color: var(--gray-6);
  --cell-large-vertical-padding: var(--padding-sm);
  --cell-large-title-font-size: var(--font-size-lg);
  --cell-large-value-font-size: var(--font-size-lg);
  --cell-large-label-font-size: var(--font-size-md);

  /* CellGroup */
  --cell-group-background-color: var(--white);
  --cell-group-title-color: var(--gray-6);
  --cell-group-title-padding: var(--padding-md) var(--padding-md) var(--padding-xs);
  --cell-group-title-font-size: var(--font-size-md);
  --cell-group-title-line-height: 32rpx;
  --cell-group-inset-padding: 0 var(--padding-md);
  --cell-group-inset-border-radius: var(--border-radius-lg);
  --cell-group-inset-title-padding: var(--padding-md) var(--padding-md) var(--padding-xs) var(--padding-xl);

  /* Checkbox */
  --checkbox-size: 40rpx;
  --checkbox-border-color: var(--gray-5);
  --checkbox-transition-duration: 0.2s;
  --checkbox-label-margin: 20rpx;
  --checkbox-label-color: var(--text-color);
  --checkbox-checked-icon-color: var(--blue);
  --checkbox-disabled-icon-color: var(--gray-5);
  --checkbox-disabled-label-color: var(--gray-5);
  --checkbox-disabled-background-color: var(--border-color);

  /* Circle */
  --circle-text-color: var(--text-color);

  /* Collapse */
  --collapse-item-transition-duration: 0.3s;
  --collapse-item-content-padding: 30rpx;
  --collapse-item-content-font-size: 26rpx;
  --collapse-item-content-line-height: 1.5;
  --collapse-item-content-text-color: var(--gray-6);
  --collapse-item-content-background-color: var(--white);
  --collapse-item-title-disabled-color: var(--gray-5);

  /* CountDown */
  --count-down-text-color: var(--text-color);
  --count-down-font-size: var(--font-size-md);
  --count-down-line-height: 40rpx;

  /* Dialog */
  --dialog-width: 640rpx;
  --dialog-small-screen-width: 90%;
  --dialog-font-size: var(--font-size-lg);
  --dialog-border-radius: 32rpx;
  --dialog-background-color: var(--white);
  --dialog-header-font-weight: var(--font-weight-bold);
  --dialog-header-line-height: 48rpx;
  --dialog-header-padding-top: var(--padding-lg);
  --dialog-header-isolated-padding: var(--padding-lg) 0;
  --dialog-message-padding: var(--padding-lg);
  --dialog-message-font-size: var(--font-size-md);
  --dialog-message-line-height: 40rpx;
  --dialog-message-max-height: 60vh;
  --dialog-has-title-message-text-color: var(--gray-7);
  --dialog-has-title-message-padding-top: var(--padding-xs);

  /* Field */
  --field-label-color: var(--gray-7);
  --field-input-text-color: var(--text-color);
  --field-input-error-text-color: var(--red);
  --field-input-disabled-text-color: var(--gray-5);
  --field-placeholder-text-color: var(--gray-5);
  --field-icon-size: 32rpx;
  --field-clear-icon-size: 32rpx;
  --field-clear-icon-color: var(--gray-5);
  --field-icon-container-color: var(--gray-6);
  --field-error-message-color: var(--red);
  --field-error-message-text-font-size: var(--font-size-sm);
  --field-text-area-min-height: 36rpx;
  --field-word-limit-color: var(--gray-7);
  --field-word-limit-font-size: var(--font-size-sm);
  --field-word-limit-line-height: 32rpx;
  --field-word-num-full-color: var(--red);
  --field-disabled-text-color: var(--gray-5);

  /* GoodsAction */
  --goods-action-background-color: var(--white);
  --goods-action-height: 100rpx;
  --goods-action-icon-width: 96rpx;
  --goods-action-icon-height: var(--goods-action-height);
  --goods-action-icon-color: var(--text-color);
  --goods-action-icon-size: 36rpx;
  --goods-action-icon-font-size: var(--font-size-xs);
  --goods-action-icon-text-color: var(--gray-7);
  --goods-action-button-height: 80rpx;
  --goods-action-button-line-height: var(--button-line-height);
  --goods-action-button-border-radius: var(--border-radius-max);
  --goods-action-button-warning-color: var(--gradient-orange);
  --goods-action-button-danger-color: var(--gradient-red);
  --goods-action-button-plain-color: var(--white);

  /* Image */
  --image-placeholder-text-color: var(--gray-6);
  --image-placeholder-font-size: var(--font-size-md);
  --image-placeholder-background-color: var(--background-color);
  --image-loading-icon-size: 64rpx;
  --image-loading-icon-color: var(--gray-4);
  --image-error-icon-size: 64rpx;
  --image-error-icon-color: var(--gray-4);

  /* Info */
  --info-size: 32rpx;
  --info-color: var(--white);
  --info-padding: 0 6rpx;
  --info-font-size: 24rpx;
  --info-font-weight: 500;
  --info-border-width: 2rpx;
  --info-background-color: var(--red);
  --info-dot-color: var(--red);
  --info-dot-size: 16rpx;
  --info-font-family: -apple-system-font, Helvetica Neue, Arial, sans-serif;

  /* Loading */
  --loading-text-color: var(--gray-6);
  --loading-text-font-size: var(--font-size-md);
  --loading-text-line-height: 40rpx;
  --loading-spinner-color: var(--gray-5);
  --loading-spinner-size: 60rpx;
  --loading-spinner-animation-duration: 0.8s;

  /* NavBar */
  --nav-bar-height: 92rpx;
  --nav-bar-background-color: var(--white);
  --nav-bar-arrow-size: 32rpx;
  --nav-bar-icon-color: var(--blue);
  --nav-bar-text-color: var(--blue);
  --nav-bar-title-font-size: var(--font-size-lg);
  --nav-bar-title-text-color: var(--text-color);

  /* NoticeBar */
  --notice-bar-height: 80rpx;
  --notice-bar-padding: 0 var(--padding-md);
  --notice-bar-wrapable-padding: var(--padding-xs) var(--padding-md);
  --notice-bar-font-size: var(--font-size-md);
  --notice-bar-text-color: var(--orange-dark);
  --notice-bar-line-height: 48rpx;
  --notice-bar-background-color: var(--orange-light);
  --notice-bar-icon-size: 32rpx;
  --notice-bar-icon-min-width: 44rpx;

  /* Notify */
  --notify-padding: 12rpx 30rpx;
  --notify-font-size: 28rpx;
  --notify-line-height: 40rpx;
  --notify-primary-background-color: var(--blue);
  --notify-success-background-color: var(--green);
  --notify-danger-background-color: var(--red);
  --notify-warning-background-color: var(--orange);

  /* Overlay */
  --overlay-background-color: rgba(0, 0, 0, 0.7);

  /* Panel */
  --panel-background-color: var(--white);
  --panel-header-value-color: var(--red);
  --panel-footer-padding: var(--padding-xs) var(--padding-md);

  /* Picker */
  --picker-background-color: var(--white);
  --picker-toolbar-height: 88rpx;
  --picker-title-font-size: var(--font-size-lg);
  --picker-action-padding: 0 var(--padding-md);
  --picker-action-font-size: var(--font-size-md);
  --picker-confirm-action-color: var(--text-link-color);
  --picker-cancel-action-color: var(--gray-6);
  --picker-option-font-size: var(--font-size-lg);
  --picker-option-text-color: var(--black);
  --picker-loading-icon-color: var(--blue);
  --picker-loading-mask-color: rgba(255, 255, 255, 0.9);
  --picker-option-disabled-opacity: 0.3;
  --picker-option-selected-text-color: var(--text-color);

  /* Popup */
  --popup-background-color: var(--white);
  --popup-round-border-radius: 32rpx;
  --popup-close-icon-size: 36rpx;
  --popup-close-icon-color: var(--gray-6);
  --popup-close-icon-margin: 32rpx;
  --popup-close-icon-z-index: 1;

  /* Progress */
  --progress-height: 8rpx;
  --progress-background-color: var(--gray-3);
  --progress-pivot-padding: 0 10rpx;
  --progress-color: var(--blue);
  --progress-pivot-font-size: var(--font-size-xs);
  --progress-pivot-line-height: 1.6;
  --progress-pivot-background-color: var(--blue);
  --progress-pivot-text-color: var(--white);

  /* Radio */
  --radio-size: 40rpx;
  --radio-border-color: var(--gray-5);
  --radio-transition-duration: 0.2s;
  --radio-label-margin: 20rpx;
  --radio-label-color: var(--text-color);
  --radio-checked-icon-color: var(--blue);
  --radio-disabled-icon-color: var(--gray-5);
  --radio-disabled-label-color: var(--gray-5);
  --radio-disabled-background-color: var(--border-color);

  /* Rate */
  --rate-horizontal-padding: 4rpx;
  --rate-icon-size: 40rpx;
  --rate-icon-void-color: var(--gray-5);
  --rate-icon-full-color: var(--red);
  --rate-icon-disabled-color: var(--gray-5);
  --rate-icon-gutter: var(--padding-base);

  /* Switch */
  --switch-width: 2em;
  --switch-height: 1em;
  --switch-node-size: 1em;
  --switch-node-z-index: 1;
  --switch-node-background-color: var(--white);
  --switch-node-box-shadow:
    0 6rpx 2rpx 0 rgba(0, 0, 0, 0.05), 0 4rpx 4rpx 0 rgba(0, 0, 0, 0.1), 0 6rpx 6rpx 0 rgba(0, 0, 0, 0.05);
  --switch-background-color: var(--white);
  --switch-on-background-color: var(--blue);
  --switch-transition-duration: 0.3s;
  --switch-disabled-opacity: 0.4;
  --switch-border: 2rpx solid rgba(0, 0, 0, 0.1);

  /* ShareSheet */
  --share-sheet-header-padding: var(--padding-sm) var(--padding-md) var(--padding-base);
  --share-sheet-title-color: var(--text-color);
  --share-sheet-title-font-size: var(--font-size-md);
  --share-sheet-title-line-height: var(--line-height-md);
  --share-sheet-description-color: var(--gray-6);
  --share-sheet-description-font-size: var(--font-size-sm);
  --share-sheet-description-line-height: 32rpx;
  --share-sheet-icon-size: 96rpx;
  --share-sheet-option-name-color: var(--gray-7);
  --share-sheet-option-name-font-size: var(--font-size-sm);
  --share-sheet-option-description-color: var(--gray-5);
  --share-sheet-option-description-font-size: var(--font-size-sm);
  --share-sheet-cancel-button-font-size: var(--font-size-lg);
  --share-sheet-cancel-button-height: 96rpx;
  --share-sheet-cancel-button-background: var(--white);

  /* Search */
  --search-background-color: var(--gray-1);
  --search-padding: 20rpx var(--padding-sm);
  --search-input-height: 68rpx;
  --search-label-padding: 0 10rpx;
  --search-label-color: var(--text-color);
  --search-label-font-size: var(--font-size-md);
  --search-left-icon-color: var(--gray-6);
  --search-action-padding: 0 var(--padding-xs);
  --search-action-text-color: var(--text-color);
  --search-action-font-size: var(--font-size-md);

  /* Sidebar */
  --sidebar-width: 160rpx;

  /* SidebarItem */
  --sidebar-font-size: var(--font-size-md);
  --sidebar-line-height: 40rpx;
  --sidebar-text-color: var(--text-color);
  --sidebar-disabled-text-color: var(--gray-5);
  --sidebar-padding: 40rpx var(--padding-sm) 40rpx var(--padding-xs);
  --sidebar-active-color: var(--active-color);
  --sidebar-background-color: var(--background-color);
  --sidebar-selected-font-weight: var(--font-weight-bold);
  --sidebar-selected-text-color: var(--text-color);
  --sidebar-selected-border-color: var(--red);
  --sidebar-selected-background-color: var(--white);

  /* Slider */
  --slider-active-background-color: var(--blue);
  --slider-inactive-background-color: var(--gray-3);
  --slider-disabled-opacity: var(--disabled-opacity);
  --slider-bar-height: 4rpx;
  --slider-button-width: 48rpx;
  --slider-button-height: 48rpx;
  --slider-button-border-radius: 50%;
  --slider-button-background-color: var(--white);
  --slider-button-box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);

  /* Step */
  --step-text-color: var(--gray-6);
  --step-process-text-color: var(--text-color);
  --step-font-size: var(--font-size-md);
  --step-line-color: var(--border-color);
  --step-finish-line-color: var(--green);
  --step-finish-text-color: var(--text-color);
  --step-icon-size: 24rpx;
  --step-circle-size: 10rpx;
  --step-circle-color: var(--gray-6);
  --step-horizontal-title-font-size: var(--font-size-sm);

  /* Steps */
  --steps-background-color: var(--white);

  /* Stepper */
  --stepper-active-color: #e8e8e8;
  --stepper-background-color: var(--active-color);
  --stepper-button-icon-color: var(--text-color);
  --stepper-button-disabled-color: var(--background-color);
  --stepper-button-disabled-icon-color: var(--gray-5);
  --stepper-button-round-theme-color: var(--red);
  --stepper-input-width: 64rpx;
  --stepper-input-height: 56rpx;
  --stepper-input-font-size: var(--font-size-md);
  --stepper-input-line-height: normal;
  --stepper-input-text-color: var(--text-color);
  --stepper-input-disabled-text-color: var(--gray-5);
  --stepper-input-disabled-background-color: var(--active-color);
  --stepper-border-radius: var(--border-radius-md);

  /* SubmitBar */
  --submit-bar-height: 100rpx;
  --submit-bar-z-index: 100;
  --submit-bar-background-color: var(--white);
  --submit-bar-button-width: 220rpx;
  --submit-bar-price-color: var(--red);
  --submit-bar-price-font-size: var(--font-size-sm);
  --submit-bar-currency-font-size: var(--font-size-sm);
  --submit-bar-text-color: var(--text-color);
  --submit-bar-text-font-size: 28rpx;
  --submit-bar-tip-padding: 20rpx;
  --submit-bar-tip-font-size: 24rpx;
  --submit-bar-tip-line-height: 1.5;
  --submit-bar-tip-color: #f56723;
  --submit-bar-tip-background-color: #fff7cc;
  --submit-bar-tip-icon-size: 24rpx;
  --submit-bar-button-height: 80rpx;
  --submit-bar-padding: 0 var(--padding-md);
  --submit-bar-price-integer-font-size: 40rpx;
  --submit-bar-price-font-family: var(--price-integer-font-family);

  /* Tabbar */
  --tabbar-height: 100rpx;
  --tabbar-background-color: var(--white);

  /* TabbarItem */
  --tabbar-item-font-size: var(--font-size-sm);
  --tabbar-item-text-color: var(--gray-7);
  --tabbar-item-active-color: var(--blue);
  --tabbar-item-line-height: 1;
  --tabbar-item-icon-size: 44rpx;
  --tabbar-item-margin-bottom: 8rpx;

  /* Tab */
  --tab-text-color: var(--gray-7);
  --tab-active-text-color: var(--text-color);
  --tab-disabled-text-color: var(--gray-5);
  --tab-font-size: var(--font-size-md);

  /* Tabs */
  --tabs-default-color: var(--red);
  --tabs-line-height: 88rpx;
  --tabs-card-height: 60rpx;
  --tabs-nav-background-color: var(--white);
  --tabs-bottom-bar-height: 6rpx;
  --tabs-bottom-bar-color: var(--tabs-default-color);

  /* Tag */
  --tag-padding: 0 var(--padding-base);
  --tag-text-color: var(--white);
  --tag-font-size: var(--font-size-sm);
  --tag-border-radius: 4rpx;
  --tag-line-height: 32rpx;
  --tag-medium-padding: 4rpx 12rpx;
  --tag-large-padding: var(--padding-base) var(--padding-xs);
  --tag-large-border-radius: var(--border-radius-md);
  --tag-large-font-size: var(--font-size-md);
  --tag-round-border-radius: var(--border-radius-max);
  --tag-danger-color: var(--red);
  --tag-primary-color: var(--blue);
  --tag-success-color: var(--green);
  --tag-warning-color: var(--orange);
  --tag-default-color: var(--gray-6);
  --tag-plain-background-color: var(--white);

  /* Toast */
  --toast-max-width: 70%;
  --toast-font-size: 28rpx;
  --toast-text-color: var(--white);
  --toast-line-height: 40rpx;
  --toast-border-radius: var(--border-radius-lg);
  --toast-background-color: rgba(0, 0, 0, 0.7);
  --toast-icon-size: 72rpx;
  --toast-text-min-width: 192rpx;
  --toast-text-padding: var(--padding-xs) var(--padding-sm);
  --toast-default-padding: var(--padding-md);
  --toast-default-width: 176rpx;
  --toast-default-min-height: 176rpx;

  /* GridItem */
  --grid-item-content-padding: var(--padding-md) var(--padding-xs);
  --grid-item-content-background-color: var(--white);
  --grid-item-content-active-color: var(--active-color);
  --grid-item-icon-size: 52rpx;
  --grid-item-text-color: var(--gray-7);
  --grid-item-text-font-size: var(--font-size-sm);

  /* Divider */
  --divider-margin: var(--padding-md) 0;
  --divider-text-color: var(--gray-6);
  --divider-font-size: var(--font-size-md);
  --divider-line-height: 48rpx;
  --divider-border-color: var(--border-color);
  --divider-content-padding: var(--padding-md);
  --divider-content-left-width: 10%;
  --divider-content-right-width: 10%;

  /* Empty */
  --empty-padding: var(--padding-xl) 0;
  --empty-image-size: 320rpx;
  --empty-description-margin-top: var(--padding-md);
  --empty-description-padding: 0 120rpx;
  --empty-description-color: var(--gray-6);
  --empty-description-font-size: 28rpx;
  --empty-description-line-height: 40rpx;
  --empty-bottom-margin-top: 48rpx;

  /* TreeSelect */
  --tree-select-font-size: var(--font-size-md);
  --tree-select-nav-background-color: var(--background-color);
  --tree-select-content-background-color: var(--white);
  --tree-select-nav-item-padding: var(--padding-sm) var(--padding-xs) var(--padding-sm) var(--padding-sm);
  --tree-select-item-height: 88rpx;
  --tree-select-item-active-color: var(--red);
  --tree-select-item-disabled-color: var(--gray-5);

  /* Uploader */
  --uploader-size: 160rpx;
  --uploader-icon-size: 48rpx;
  --uploader-icon-color: var(--gray-4);
  --uploader-text-color: var(--gray-6);
  --uploader-text-font-size: var(--font-size-sm);
  --uploader-upload-background-color: var(--gray-1);
  --uploader-upload-active-color: var(--active-color);
  --uploader-delete-color: var(--white);
  --uploader-delete-icon-size: 28rpx;
  --uploader-delete-background-color: rgba(0, 0, 0, 0.7);
  --uploader-file-background-color: var(--background-color);
  --uploader-file-icon-size: 40rpx;
  --uploader-file-icon-color: var(--gray-7);
  --uploader-file-name-padding: 0 var(--padding-base);
  --uploader-file-name-margin-top: var(--padding-xs);
  --uploader-file-name-font-size: var(--font-size-sm);
  --uploader-file-name-text-color: var(--gray-7);
  --uploader-mask-background-color: rgba(50, 50, 51, 0.88);
  --uploader-mask-icon-size: 44rpx;
  --uploader-mask-message-font-size: var(--font-size-sm);
  --uploader-mask-message-line-height: 28rpx;
  --uploader-loading-icon-size: 44rpx;
  --uploader-loading-icon-color: var(--white);
  --uploader-disabled-opacity: var(--disabled-opacity);

  /* DropdownMenu */
  --dropdown-menu-height: 100rpx;
  --dropdown-menu-background-color: var(--white);
  --dropdown-menu-title-font-size: 30rpx;
  --dropdown-menu-title-text-color: var(--text-color);
  --dropdown-menu-title-active-text-color: var(--red);
  --dropdown-menu-title-disabled-text-color: var(--gray-6);
  --dropdown-menu-title-padding: 0 var(--padding-lg) 0 var(--padding-xs);
  --dropdown-menu-title-line-height: 36rpx;
  --dropdown-menu-option-active-color: var(--red);
  --dropdown-menu-box-shadow: 0 4rpx 24rpx rgba(100, 101, 102, 0.12);

  /* IndexAnchor */
  --index-anchor-padding: 0 var(--padding-md);
  --index-anchor-text-color: var(--text-color);
  --index-anchor-font-weight: 500;
  --index-anchor-font-size: var(--font-size-md);
  --index-anchor-line-height: 64rpx;
  --index-anchor-background-color: transparent;
  --index-anchor-active-background-color: var(--white);
  --index-anchor-active-text-color: var(--green);

  /* IndexBar */
  --index-bar-index-font-size: var(--font-size-xs);
  --index-bar-index-line-height: 28rpx;

  /* skeleton */
  --skeleton-padding: 0 var(--padding-md);
  --skeleton-row-height: 32rpx;
  --skeleton-row-background-color: var(--gray-2);
  --skeleton-row-margin-top: var(--padding-sm);
  --skeleton-avatar-background-color: var(--gray-2);
  --skeleton-animation-duration: 1.2s;

  /* Cascader */
  --cascader-header-height: 96rpx;
  --cascader-header-padding: 0 32rpx;
  --cascader-title-font-size: 32rpx;
  --cascader-title-line-height: 40rpx;
  --cascader-close-icon-size: 44rpx;
  --cascader-close-icon-color: #c8c9cc;
  --cascader-selected-icon-size: 36rpx;
  --cascader-tabs-height: 96rpx;
  --cascader-active-color: var(--blue);
  --cascader-options-height: 768rpx;
  --cascader-option-disabled-color: #c8c9cc;
  --cascader-tab-color: #323233;
  --cascader-unselected-tab-color: #969799;
}
